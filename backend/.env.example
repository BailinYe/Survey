# Copy this file to .env and fill in actual values

# MongoDB connection string
# Local development: mongodb://localhost:27017/survey_dev
# MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/survey_dev
MONGODB_URI=

# Server port
PORT=3000

# Environment (development | production | test)
NODE_ENV=development

# JWT secret (use a strong password in production)
JWT_SECRET=
